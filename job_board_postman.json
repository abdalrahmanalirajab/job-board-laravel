          "name": "Candidate tries Employer Route (should fail 403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{candidate_token}}" }],
            "url": { "raw": "{{base_url}}/api/employer/jobs", "host": ["{{base_url}}"], "path": ["api", "employer", "jobs"] }
