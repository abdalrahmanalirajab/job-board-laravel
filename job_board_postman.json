          "name": "Filter by Date Posted",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/jobs?date_from=2026-01-01",
              "host": ["{{base_url}}"], "path": ["api", "jobs"],
              "query": [{ "key": "date_from", "value": "2026-01-01" }]
            }
          }
        },
        {
          "name": "Sort by Salary High to Low",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/jobs?sort_by=salary_high",
              "host": ["{{base_url}}"], "path": ["api", "jobs"],
              "query": [{ "key": "sort_by", "value": "salary_high" }]
