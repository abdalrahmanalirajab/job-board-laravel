    {
      "name": "👔 EMPLOYER - Job Management",
      "item": [
        {
          "name": "List My Jobs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{employer_token}}" }],
            "url": { "raw": "{{base_url}}/api/employer/jobs", "host": ["{{base_url}}"], "path": ["api", "employer", "jobs"] }
          }
        },
        {
          "name": "Create Job Listing",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('job_id', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{employer_token}}" }],
            "url": { "raw": "{{base_url}}/api/employer/jobs", "host": ["{{base_url}}"], "path": ["api", "employer", "jobs"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Senior Laravel Developer\",\n  \"description\": \"We are looking for a skilled Laravel developer to join our team and build amazing APIs.\",\n  \"responsibilities\": \"Build and maintain REST APIs, write clean code, do code reviews\",\n  \"skills_required\": \"Laravel, MySQL, REST APIs, Git\",\n  \"category_id\": 1,\n  \"location\": \"Cairo, Egypt\",\n  \"work_type\": \"remote\",\n  \"experience_level\": \"senior\",\n  \"salary_min\": 2000,\n  \"salary_max\": 4000,\n  \"deadline\": \"2026-12-31\",\n  \"technologies\": [\"Laravel\", \"MySQL\", \"Vue.js\", \"Git\"]\n}"
            }
          }
        },
        {
          "name": "Create Job - Missing Fields (should fail 422)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{employer_token}}" }],
            "url": { "raw": "{{base_url}}/api/employer/jobs", "host": ["{{base_url}}"], "path": ["api", "employer", "jobs"] },
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        },
        {
          "name": "Create Job - Invalid Work Type (should fail 422)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{employer_token}}" }],
            "url": { "raw": "{{base_url}}/api/employer/jobs", "host": ["{{base_url}}"], "path": ["api", "employer", "jobs"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Job\",\n  \"work_type\": \"invalid_type\"\n}"
            }
          }
        },
        {
          "name": "Show Single My Job",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{employer_token}}" }],
            "url": { "raw": "{{base_url}}/api/employer/jobs/{{job_id}}", "host": ["{{base_url}}"], "path": ["api", "employer", "jobs", "{{job_id}}"] }
          }
        },
        {
          "name": "Update My Job",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{employer_token}}" }],
            "url": { "raw": "{{base_url}}/api/employer/jobs/{{job_id}}", "host": ["{{base_url}}"], "path": ["api", "employer", "jobs", "{{job_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Laravel Developer Position\",\n  \"salary_min\": 2500,\n  \"salary_max\": 5000,\n  \"technologies\": [\"Laravel\", \"React\", \"Docker\"]\n}"
            }
          }
        },
        {
          "name": "Update Another Employer Job (should fail 403)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{employer_token}}" }],
            "url": { "raw": "{{base_url}}/api/employer/jobs/999", "host": ["{{base_url}}"], "path": ["api", "employer", "jobs", "999"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Hacked Job\"\n}"
            }
          }
        },
        {
          "name": "Delete My Job",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{employer_token}}" }],
            "url": { "raw": "{{base_url}}/api/employer/jobs/{{job_id}}", "host": ["{{base_url}}"], "path": ["api", "employer", "jobs", "{{job_id}}"] }
