    {
      "name": "💼 JOBS (Public)",
      "item": [
        {
          "name": "Get All Approved Jobs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/jobs", "host": ["{{base_url}}"], "path": ["api", "jobs"] }
          }
        },
        {
          "name": "Search Jobs by Keyword",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/jobs?search=laravel",
              "host": ["{{base_url}}"], "path": ["api", "jobs"],
              "query": [{ "key": "search", "value": "laravel" }]
            }
          }
        },
        {
          "name": "Filter by Category",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
