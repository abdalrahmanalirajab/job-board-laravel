    {
      "name": "📝 APPLICATIONS",
      "item": [
        {
          "name": "Apply for a Job (JSON)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('application_id', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{candidate_token}}" }],
            "url": { "raw": "{{base_url}}/api/jobs/1/apply", "host": ["{{base_url}}"], "path": ["api", "jobs", "1", "apply"] },
            "body": {
              "mode": "raw",
