        {
          "name": "Filter by Salary Range",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/jobs?salary_min=1000&salary_max=5000",
              "host": ["{{base_url}}"], "path": ["api", "jobs"],
              "query": [{ "key": "salary_min", "value": "1000" }, { "key": "salary_max", "value": "5000" }]
            }
          }
        },
