              "host": ["{{base_url}}"], "path": ["api", "jobs"],
              "query": [{ "key": "category_id", "value": "1" }]
            }
          }
        },
        {
          "name": "Filter by Work Type (remote)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/jobs?work_type=remote",
              "host": ["{{base_url}}"], "path": ["api", "jobs"],
              "query": [{ "key": "work_type", "value": "remote" }]
            }
          }
        },
        {
          "name": "Filter by Location",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/jobs?location=Cairo",
              "host": ["{{base_url}}"], "path": ["api", "jobs"],
              "query": [{ "key": "location", "value": "Cairo" }]
            }
          }
        },
        {
          "name": "Filter by Experience Level",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/jobs?experience_level=senior",
              "host": ["{{base_url}}"], "path": ["api", "jobs"],
              "query": [{ "key": "experience_level", "value": "senior" }]
